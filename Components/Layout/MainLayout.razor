@inherits LayoutComponentBase
<div class="shell">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <!-- Brand -->
        <div class="brand">
            <div class="brand-name">Kolekta</div>
            <div class="brand-sub">card drop game</div>
            <span class="brand-line"></span>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav">
            <div class="nav-label">Navigate</div>

            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon">⌂</span>
                <span>Home</span>
            </NavLink>

            <NavLink class="nav-link" href="/drop">
                <span class="nav-icon">✦</span>
                <span>Drop Arena</span>
            </NavLink>

            <NavLink class="nav-link" href="/inventory">
                <span class="nav-icon">◈</span>
                <span>Collection</span>
            </NavLink>
        </nav>

        <!-- Footer -->
        <div class="sidebar-footer">
            <div class="ornament-dots">
                <div class="ornament-dot"></div>
                <div class="ornament-dot"></div>
                <div class="ornament-dot"></div>
            </div>
            <div class="sidebar-footer-text">First come, first claimed.</div>
        </div>

    </aside>

    <!-- MAIN -->
    <main class="main-content">
        <div class="main-inner">
            @Body
        </div>
    </main>

</div>
